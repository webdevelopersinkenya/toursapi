{
  "openapi": "3.0.0",
  "info": {
    "title": "Tours Management API",
    "version": "1.0.0",
    "description": "API documentation for Users, Auth, Bookings, Destinations, and Tours management system"
  },

  "servers": [
    {
      "url": "http://localhost:5000"
    }
  ],

  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },

  "security": [
    {
      "BearerAuth": []
    }
  ],

  "tags": [
    {
      "name": "Users",
      "description": "User management (CRUD)"
    },
    {
      "name": "Auth",
      "description": "Authentication (Register & Login)"
    },
    {
      "name": "Bookings",
      "description": "Booking management"
    },
    {
      "name": "Destinations",
      "description": "Destinations management"
    },
    {
      "name": "Tours",
      "description": "Tours management"
    }
  ],

  "paths": {

    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register user",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User registered successfully" }
        }
      }
    },

    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login user",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful (returns JWT)"
          }
        }
      }
    },

    "/api/users": {
      "get": {
        "tags": ["Users"],
        "summary": "Get all users",
        "responses": {
          "200": { "description": "Success" }
        }
      },
      "post": {
        "tags": ["Users"],
        "summary": "Create user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" }
        }
      }
    },

    "/api/users/{id}": {
      "get": {
        "tags": ["Users"],
        "summary": "Get user by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Success" },
          "404": { "description": "Not found" }
        }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Update user",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Updated" }
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Delete user",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Deleted" }
        }
      }
    },

    "/api/bookings": {
      "get": {
        "tags": ["Bookings"],
        "summary": "Get all bookings",
        "responses": {
          "200": { "description": "Success" }
        }
      },
      "post": {
        "tags": ["Bookings"],
        "summary": "Create booking",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["tourId", "userId", "fullName", "email", "date", "numberOfPeople"],
                "properties": {
                  "tourId": { "type": "string" },
                  "userId": { "type": "string" },
                  "fullName": { "type": "string" },
                  "email": { "type": "string" },
                  "date": { "type": "string" },
                  "numberOfPeople": { "type": "number" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" }
        }
      }
    },

    "/api/bookings/{id}": {
      "put": {
        "tags": ["Bookings"],
        "summary": "Update booking",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Updated" }
        }
      },
      "delete": {
        "tags": ["Bookings"],
        "summary": "Delete booking",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Deleted" }
        }
      }
    },

    "/api/destinations": {
      "get": {
        "tags": ["Destinations"],
        "summary": "Get all destinations",
        "responses": {
          "200": { "description": "Success" }
        }
      },
      "post": {
        "tags": ["Destinations"],
        "summary": "Create destination",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "country"],
                "properties": {
                  "name": { "type": "string" },
                  "country": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" }
        }
      }
    },

    "/api/destinations/{id}": {
      "get": {
        "tags": ["Destinations"],
        "summary": "Get destination by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      },
      "put": {
        "tags": ["Destinations"],
        "summary": "Update destination",
        "responses": {
          "200": { "description": "Updated" }
        }
      },
      "delete": {
        "tags": ["Destinations"],
        "summary": "Delete destination",
        "responses": {
          "200": { "description": "Deleted" }
        }
      }
    },

    

    "/api/tours": {
      "get": {
        "tags": ["Tours"],
        "summary": "Get all tours",
        "responses": {
          "200": { "description": "Success" }
        }
      },
      "post": {
        "tags": ["Tours"],
        "summary": "Create tour",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "destination", "price"],
                "properties": {
                  "name": { "type": "string" },
                  "destination": { "type": "string" },
                  "price": { "type": "number" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" }
        }
      }
    },

    "/api/tours/{id}": {
      "put": {
        "tags": ["Tours"],
        "summary": "Update tour",
        "responses": {
          "200": { "description": "Updated" }
        }
      },
      "delete": {
        "tags": ["Tours"],
        "summary": "Delete tour",
        "responses": {
          "200": { "description": "Deleted" }
        }
      }
    }
  }
}