{
  "openapi": "3.0.0",
  "info": {
    "title": "Tours Management API",
    "version": "1.0.0",
    "description": "API documentation for Users, Auth, Bookings, Destinations, and Tours management system"
  },
  "servers": [
    {
      "url": "http://localhost:5000"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    { "name": "Auth", "description": "Authentication (Register & Login)" },
    { "name": "Users", "description": "User management (CRUD)" },
    { "name": "Bookings", "description": "Booking management" },
    { "name": "Destinations", "description": "Destination management" },
    { "name": "Tours", "description": "Tours management" }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register user",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User registered successfully" }
        }
      }
    },

    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login user",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "JWT token returned" }
        }
      }
    },

    "/api/users": {
      "get": {
        "tags": ["Users"],
        "summary": "Get all users",
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "tags": ["Users"],
        "summary": "Create user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Created" } }
      }
    },

    "/api/users/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" }
        }
      ],
      "get": {
        "tags": ["Users"],
        "summary": "Get user by ID",
        "responses": { "200": { "description": "Success" } }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Update user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Delete user",
        "responses": { "200": { "description": "Deleted" } }
      }
    },

    "/api/bookings": {
      "get": {
        "tags": ["Bookings"],
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "tags": ["Bookings"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["customerName", "email", "tourId"],
                "properties": {
                  "customerName": { "type": "string" },
                  "email": { "type": "string" },
                  "tourId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Created" } }
      }
    },

    "/api/bookings/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" }
        }
      ],
      "put": {
        "tags": ["Bookings"],
        "summary": "Update booking",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["Bookings"],
        "summary": "Delete booking",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Deleted" } }
      }
    },

    "/api/destinations": {
      "get": {
        "tags": ["Destinations"],
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "tags": ["Destinations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "country"],
                "properties": {
                  "name": { "type": "string" },
                  "country": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Created" } }
      }
    },

    "/api/destinations/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" }
        }
      ],
      "get": {
        "tags": ["Destinations"],
        "summary": "Get destination by ID",
        "responses": { "200": { "description": "Success" } }
      },
      "put": {
        "tags": ["Destinations"],
        "summary": "Update destination",
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["Destinations"],
        "summary": "Delete destination",
        "responses": { "200": { "description": "Deleted" } }
      }
    },

    "/api/tours": {
      "get": {
        "tags": ["Tours"],
        "summary": "Get all tours",
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "tags": ["Tours"],
        "summary": "Create a new tour",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "description", "price", "duration", "destinationId"],
                "properties": {
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "price": { "type": "number" },
                  "duration": { "type": "number" },
                  "destinationId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created successfully" },
          "400": { "description": "Validation error" }
        }
      }
    },

    "/api/tours/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" }
        }
      ],
      "get": {
        "tags": ["Tours"],
        "summary": "Get tour by ID",
        "responses": {
          "200": { "description": "Success" },
          "404": { "description": "Tour not found" }
        }
      },
      "put": {
        "tags": ["Tours"],
        "summary": "Update tour",
        "responses": {
          "200": { "description": "Updated successfully" },
          "400": { "description": "Validation error" },
          "404": { "description": "Tour not found" }
        }
      },
      "delete": {
        "tags": ["Tours"],
        "summary": "Delete tour",
        "responses": {
          "200": { "description": "Deleted successfully" },
          "404": { "description": "Tour not found" }
        }
      }
    }
  }
}